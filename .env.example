# Atlas — environment template. Copy to `.env` and fill real values.
# NEVER commit `.env`. No secrets live in code (CLAUDE.md). All model config is
# env-swappable — never hardcoded.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────
# Remote Ollama (LLM) — the model NEVER runs locally. Points at the cloud GPU
# endpoint (JarvisLabs / E2E). Resuming a paused instance may change this URL
# (see RUNBOOK §2) — update here, the app stack is indifferent to which GPU is live.
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
# Embedding dimension is fixed by OLLAMA_EMBED_MODEL and pins the pgvector column
# (ADR-0005). Changing the embed model later requires a re-embed/migration.
EMBED_DIM=768

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL + pgvector (vector store + metadata + RBAC + agent checkpoints).
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-locally
# rag-engine derives its JDBC datasource URL from the POSTGRES_* values above
# (jdbc:postgresql://$HOST:$PORT/$DB). Set SPRING_DATASOURCE_URL only to override
# that default (e.g. a managed instance with extra JDBC params). Flyway migrations
# in rag-engine/src/main/resources/db/migration run against this datasource at startup.
# SPRING_DATASOURCE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Redis (cache / rate limiting — used from P3).
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Application (rag-engine — the P0 connectivity probe lives here).
# ─────────────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
RAG_ENGINE_PORT=8081

# ─────────────────────────────────────────────────────────────────────────────
# Ingestion pipeline (P1, rag-engine). Defaults are baked in; override only to
# point at a different corpus or to tune chunking. Chunk sizing per ADR-0011.
# ─────────────────────────────────────────────────────────────────────────────
# ATLAS_INGEST_LAYER1_MANIFEST=classpath:corpus/layer1/manifest.json
# ATLAS_INGEST_LAYER2_GLOB=classpath:corpus/layer2/*.md
# ATLAS_INGEST_CHUNK_SIZE=512
# ATLAS_INGEST_CHUNK_OVERLAP=64
# ATLAS_INGEST_TRUSTED_ORIGINS=classpath:corpus/,classpath:/corpus/
