# Atlas reverse proxy (P5 Task 7 — D-P5-2/5, G-P5-2/3).
#
# One origin in front of the whole stack: serves the built React UI as static files and
# path-routes API calls to the FROZEN backends (no CORS, one TLS endpoint). Emits a strict
# Content-Security-Policy + security headers — the independent second wall behind the
# client-side sanitizer (LLM05 defense-in-depth, ADR-0058).
#
# Upstreams are env-driven so the SAME proxy works for host-run backends (dev default,
# host.docker.internal) and in-compose backends (gateway:8080 / agents:8083 / mcp-tools:8082):
#   GATEWAY_UPSTREAM  AGENTS_UPSTREAM  MCP_UPSTREAM  PROXY_SITE_ADDRESS  PROXY_TLS  GRAFANA_ORIGIN
#
# TLS: `internal` (Caddy's local CA / self-signed) satisfies the P5 local-TLS gate today;
# set PROXY_TLS to an ACME email (or a domain in PROXY_SITE_ADDRESS) for the live deploy (Task 10).
{
	admin off
	# `internal`/self-signed local TLS by default; ACME for the live domain (Task 10).
	auto_https disable_redirects
}

# ── Container health listener (P6 Task 2) ─────────────────────────────────────
# A dedicated, host-agnostic HTTP listener on an INTERNAL-ONLY port (never published in
# compose) so the Docker HEALTHCHECK / orchestrator probe does not depend on the public
# host name or TLS. Returns 200 on /healthz, 404 otherwise.
:9180 {
	respond /healthz "ok" 200
	respond 404
}

{$PROXY_SITE_ADDRESS:localhost} {
	tls {$PROXY_TLS:internal}

	encode gzip

	# ── Security headers (G-P5-2) — defense-in-depth behind the client sanitizer ──
	# Strict CSP: NO 'unsafe-inline' / 'unsafe-eval' for scripts. The Vite build emits
	# only hashed, external module scripts + a linked stylesheet (verified: no inline
	# <script>/<style>), so 'self' suffices. `frame-src` admits the optional Grafana
	# embed origin (GRAFANA_ORIGIN); `frame-ancestors 'self'` blocks clickjacking.
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src 'self' {$GRAFANA_ORIGIN:}; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "SAMEORIGIN"
		# Don't advertise the server software.
		-Server
	}

	# ── API routing (D-P5-2) — order matters: specific paths BEFORE the /v1/* catch-all ──
	# Agents: planner/executor runs + HITL resume + trace polling.
	handle /v1/agent/* {
		reverse_proxy {$AGENTS_UPSTREAM:host.docker.internal:8083}
	}
	# mcp-tools: the read-only audit query (compliance-gated). The /mcp tool endpoint is
	# NOT proxied to the browser — only the agent calls it inside the network.
	handle /v1/audit* {
		reverse_proxy {$MCP_UPSTREAM:host.docker.internal:8082}
	}
	# Gateway: sim-IdP auth + RAG query (and any other /v1/* surface).
	handle /v1/* {
		reverse_proxy {$GATEWAY_UPSTREAM:host.docker.internal:8080}
	}

	# ── Static SPA (the built UI) with client-side-routing fallback ──
	handle {
		root * /srv/ui
		try_files {path} /index.html
		file_server
	}
}
