{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["atlas", "p4", "agents"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Atlas — Agent Orchestrator (P4)",
  "uid": "atlas-agents",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Agent runs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Run rate by terminal status",
      "description": "Runs reaching COMPLETED / REJECTED / FAILED.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(atlas_agent_runs_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Runs started / awaiting approval (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "atlas_agent_runs_started_total", "legendFormat": "started" },
        { "refId": "B", "expr": "atlas_agent_awaiting_approval_total", "legendFormat": "awaiting approval" }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Governed action + approval",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tool-call rate (open_draft_sar) by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(atlas_agent_tool_calls_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Failures rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(atlas_agent_failures_total[5m])", "legendFormat": "failures/s" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Approval latency (p50 / p95)",
      "description": "Seconds between run start and the human approval decision.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(rate(atlas_agent_approval_latency_seconds_bucket[30m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(atlas_agent_approval_latency_seconds_bucket[30m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
